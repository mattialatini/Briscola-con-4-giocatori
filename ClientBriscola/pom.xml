<?xml version="1.0" encoding="UTF-8"?>
<!-- Dichiarazione XML con codifica UTF-8 -->

<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
             http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <!-- Versione del modello POM utilizzato da Maven -->
    <modelVersion>4.0.0</modelVersion>

    <!-- Identificativo del gruppo (di solito organizzazione o scuola) -->
    <groupId>it.edu.marconipontedera</groupId>

    <!-- Nome del progetto -->
    <artifactId>ClientBriscola</artifactId>

    <!-- Versione del progetto -->
    <version>1.0-SNAPSHOT</version>

    <!-- Tipo di pacchetto generato (file jar eseguibile) -->
    <packaging>jar</packaging>

    <!-- Proprietà usate nel progetto -->
    <properties>

        <!-- Versione di Java usata per compilare -->
        <maven.compiler.source>17</maven.compiler.source>

        <!-- Versione di Java usata per eseguire -->
        <maven.compiler.target>17</maven.compiler.target>

        <!-- Versione della libreria JavaFX -->
        <javafx.version>17.0.2</javafx.version>

        <!-- Codifica dei file del progetto -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Classe principale che avvia il programma -->
        <mainClass>it.edu.marconipontedera.ClientBriscola.ClientBriscola</mainClass>

    </properties>

    <!-- Librerie esterne usate dal progetto -->
    <dependencies>

        <!-- Libreria JavaFX per i controlli grafici (bottoni, label, ecc.) -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- Libreria JavaFX per usare i file FXML -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>

    </dependencies>

    <!-- Configurazione della build del progetto -->
    <build>

        <!-- Risorse del progetto (immagini, file, ecc.) -->
        <resources>
            <resource>

                <!-- Cartella delle risorse -->
                <directory>src/resources</directory>

                <!-- Dove verranno copiate nella build -->
                <targetPath>resources</targetPath>

            </resource>
        </resources>

        <!-- Cartella dei file sorgente Java -->
        <sourceDirectory>src</sourceDirectory>

        <!-- Plugin Maven utilizzati -->
        <plugins>

            <!-- Plugin per compilare il codice Java -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>

                <!-- Versione del plugin -->
                <version>3.11.0</version>

                <configuration>

                    <!-- Versione Java da usare -->
                    <release>17</release>

                </configuration>
            </plugin>

            <!-- Plugin che copia le librerie JavaFX nella cartella target/dependency -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>

                <!-- Versione del plugin -->
                <version>3.6.0</version>

                <executions>
                    <execution>

                        <!-- Nome dell'esecuzione -->
                        <id>copy-dependencies</id>

                        <!-- Fase di build in cui viene eseguito -->
                        <phase>process-classes</phase>

                        <!-- Azione da eseguire -->
                        <goals>
                            <goal>copy-dependencies</goal>
                        </goals>

                        <configuration>

                            <!-- Cartella di destinazione delle dipendenze -->
                            <outputDirectory>${project.build.directory}/dependency</outputDirectory>

                        </configuration>

                    </execution>
                </executions>
            </plugin>

            <!-- Plugin JavaFX per avviare il progetto con mvn javafx:run -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>

                <!-- Versione del plugin -->
                <version>0.0.8</version>

                <configuration>

                    <!-- Classe principale da eseguire -->
                    <mainClass>${mainClass}</mainClass>

                </configuration>
            </plugin>

            <!-- Plugin che permette di avviare il programma con il tasto Run -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>

                <!-- Versione del plugin -->
                <version>3.5.1</version>

                <configuration>

                    <!-- Classe principale da eseguire -->
                    <mainClass>${mainClass}</mainClass>

                    <!-- Argomenti della JVM -->
                    <vmArgs>

                        <!-- Specifica il module path -->
                        <vmArg>--module-path</vmArg>

                        <!-- Cartella dove sono state copiate le librerie -->
                        <vmArg>${project.build.directory}/dependency</vmArg>

                        <!-- Moduli JavaFX da caricare -->
                        <vmArg>--add-modules</vmArg>

                        <!-- Moduli JavaFX utilizzati -->
                        <vmArg>javafx.controls,javafx.fxml</vmArg>

                    </vmArgs>

                </configuration>
            </plugin>

        </plugins>
    </build>

</project>